{
    "name": "kixx-app",

    "environments": {
        "development": {
            "HYPERVIEW": {
                "ALLOW_JSON_RESPONSE": true,
                "USE_PAGE_CACHE": false,
                "USE_TEMPLATE_CACHE": false
            },
            "SECRET_ENCRYPTION": {
                "PBKDF2_ITERATIONS": 50000
            },
            "RATE_LIMIT": {
                "ADMIN_LOGIN": { "maxFailures": 5, "windowSeconds": 900, "cooldownSeconds": 900 },
                "ADMIN_SIGNUP": { "maxFailures": 10, "windowSeconds": 900, "cooldownSeconds": 900 },
                "ADMIN_INVITE": { "maxFailures": 3, "windowSeconds": 900, "cooldownSeconds": 3600 }
            },
            "DOCUMENT_STORE": {
                "path": "./data/nodejs_app/document_store.sqlite"
            },
            "KEY_VALUE_STORE": {
                "path": "./data/nodejs_app/key_value_store.sqlite"
            },
            "OBJECT_STORE": {
                "path": "./data/nodejs_app/object_store",
                "buckets": {
                    "uploads": {}
                }
            },
            "PAGE_DATA_STORE": {
                "directory": "./pages"
            },
            "TEMPLATE_FILE_STORE": {
                "directory": "./templates"
            },
            "STATIC_FILE_STORE": {
                "directory": "./public"
            }
        },
        "staging": {
            "HYPERVIEW": {
                "ALLOW_JSON_RESPONSE": false,
                "USE_PAGE_CACHE": true,
                "USE_TEMPLATE_CACHE": true
            },
            "SECRET_ENCRYPTION": {
                "PBKDF2_ITERATIONS": 50000
            },
            "RATE_LIMIT": {
                "ADMIN_LOGIN": { "maxFailures": 5, "windowSeconds": 900, "cooldownSeconds": 900 },
                "ADMIN_SIGNUP": { "maxFailures": 10, "windowSeconds": 900, "cooldownSeconds": 900 },
                "ADMIN_INVITE": { "maxFailures": 3, "windowSeconds": 900, "cooldownSeconds": 3600 }
            },
            "DOCUMENT_STORE": {
                "path": "../data/nodejs_app/document_store.sqlite"
            },
            "KEY_VALUE_STORE": {
                "path": "../data/nodejs_app/key_value_store.sqlite"
            },
            "OBJECT_STORE": {
                "path": "../data/nodejs_app/object_store",
                "buckets": {
                    "uploads": {}
                }
            },
            "PAGE_DATA_STORE": {
                "directory": "./pages"
            },
            "TEMPLATE_FILE_STORE": {
                "directory": "./templates"
            },
            "STATIC_FILE_STORE": {
                "directory": "./public"
            }
        },
        "production": {
            "HYPERVIEW": {
                "ALLOW_JSON_RESPONSE": false,
                "USE_PAGE_CACHE": true,
                "USE_TEMPLATE_CACHE": true
            },
            "SECRET_ENCRYPTION": {
                "PBKDF2_ITERATIONS": 50000
            },
            "RATE_LIMIT": {
                "ADMIN_LOGIN": { "maxFailures": 5, "windowSeconds": 900, "cooldownSeconds": 900 },
                "ADMIN_SIGNUP": { "maxFailures": 10, "windowSeconds": 900, "cooldownSeconds": 900 },
                "ADMIN_INVITE": { "maxFailures": 3, "windowSeconds": 900, "cooldownSeconds": 3600 }
            },
            "DOCUMENT_STORE": {
                "path": "../data/nodejs_app/document_store.sqlite"
            },
            "KEY_VALUE_STORE": {
                "path": "../data/nodejs_app/key_value_store.sqlite"
            },
            "OBJECT_STORE": {
                "path": "../data/nodejs_app/object_store",
                "buckets": {
                    "uploads": {}
                }
            },
            "PAGE_DATA_STORE": {
                "directory": "./pages"
            },
            "TEMPLATE_FILE_STORE": {
                "directory": "./templates"
            },
            "STATIC_FILE_STORE": {
                "directory": "./public"
            }
        }
    }
}
