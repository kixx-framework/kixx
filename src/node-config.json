{
    "name": "kixx-app",

    "environments": {
        "development": {
            "HYPERVIEW": {
                "ALLOW_JSON_RESPONSE": true,
                "USE_PAGE_CACHE": false,
                "USE_TEMPLATE_CACHE": false
            },
            "SECRET_ENCRYPTION": {
                "PBKDF2_ITERATIONS": 50000
            },
            "DOCUMENT_STORE": {
                "path": "../data/nodejs_app/document_store.sqlite"
            },
            "KEY_VALUE_STORE": {
                "path": "../data/nodejs_app/key_value_store.sqlite"
            },
            "PAGE_DATA_STORE": {
                "directory": "./pages"
            },
            "TEMPLATE_FILE_STORE": {
                "directory": "./templates"
            },
            "STATIC_FILE_STORE": {
                "directory": "./public"
            }
        },
        "staging": {
            "HYPERVIEW": {
                "ALLOW_JSON_RESPONSE": false,
                "USE_PAGE_CACHE": true,
                "USE_TEMPLATE_CACHE": true
            },
            "SECRET_ENCRYPTION": {
                "PBKDF2_ITERATIONS": 50000
            },
            "DOCUMENT_STORE": {
                "path": "../data/nodejs_app/document_store.sqlite"
            },
            "KEY_VALUE_STORE": {
                "path": "../data/nodejs_app/key_value_store.sqlite"
            },
            "PAGE_DATA_STORE": {
                "directory": "./pages"
            },
            "TEMPLATE_FILE_STORE": {
                "directory": "./templates"
            },
            "STATIC_FILE_STORE": {
                "directory": "./public"
            }
        },
        "production": {
            "HYPERVIEW": {
                "ALLOW_JSON_RESPONSE": false,
                "USE_PAGE_CACHE": true,
                "USE_TEMPLATE_CACHE": true
            },
            "SECRET_ENCRYPTION": {
                "PBKDF2_ITERATIONS": 50000
            },
            "DOCUMENT_STORE": {
                "path": "../data/nodejs_app/document_store.sqlite"
            },
            "KEY_VALUE_STORE": {
                "path": "../data/nodejs_app/key_value_store.sqlite"
            },
            "PAGE_DATA_STORE": {
                "directory": "./pages"
            },
            "TEMPLATE_FILE_STORE": {
                "directory": "./templates"
            },
            "STATIC_FILE_STORE": {
                "directory": "./public"
            }
        }
    }
}
